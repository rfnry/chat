{
  "name": "@rfnry/chat-client-react",
  "version": "0.2.0",
  "type": "module",
  "description": "rfnry/chat - react client",
  "author": "rfnry (https://github.com/rfnry)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rfnry/chat.git",
    "directory": "packages/client-react"
  },
  "homepage": "https://github.com/rfnry/chat",
  "bugs": "https://github.com/rfnry/chat/issues",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "rfnry",
    "chat",
    "agent",
    "ai",
    "react"
  ],
  "engines": {
    "node": ">=22.12.0"
  },
  "main": "./dist/main.cjs",
  "module": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/main.d.ts",
        "default": "./dist/main.js"
      },
      "require": {
        "types": "./dist/main.d.cts",
        "default": "./dist/main.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --fix .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "dependencies": {
    "@rfnry/chat-protocol": "file:../../../types/packages/chat-typescript",
    "@tanstack/react-query": "^5.99.2",
    "socket.io-client": "^4.8.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "jsdom": "^29.0.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
